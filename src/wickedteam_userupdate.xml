<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" version="4.0" method="upgrade" client="site" group="content">
	<name>WickedTeam Userupdate</name>
	<creationDate>22-Jan-2025</creationDate>
	<author>Heinl Christian</author>
	<authorEmail>heinchrs@gmail.com</authorEmail>
	<authorUrl/>
	<copyright>Heinl Christian, 2025</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<version>2.0.0</version>
	<description>PLG_WICKEDTEAM_USERUPDATE_DESCRIPTION</description>
	<files folder="site">
		<folder>language</folder>
		<filename>index.html</filename>
		<filename plugin="wickedteam_userupdate">wickedteam_userupdate.php</filename>
	</files>
	<params/>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field name="notification_email" type="text" size="50" default="" label="PLG_WICKEDTEAM_USERUPDATE_NOTIFICATION_EMAIL_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_NOTIFICATION_EMAIL_DESC"/>
				<field name="send_notification" type="list" default="" label="PLG_WICKEDTEAM_USERUPDATE_SEND_NOTIFICATION_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_SEND_NOTIFICATION_DESC">
					<option value="0">JNO</option><option value="1">PLG_WICKEDTEAM_USERUPDATE_SEND_NOTIFICATION_BACKEND_FRONTEND</option>
					<option value="2">PLG_WICKEDTEAM_USERUPDATE_SEND_NOTIFICATION_FRONTEND</option>
					<option value="3">PLG_WICKEDTEAM_USERUPDATE_SEND_NOTIFICATION_BACKEND</option>
				</field>
				<field name="lastname_field" type="sql" default="" label="PLG_WICKEDTEAM_USERUPDATE_LASTNAME_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_LASTNAME_DESC" required="true" query="SELECT title, id FROM #__fields WHERE context='com_wickedteam.member'" key_field="id" value_field="title"/>
				<field name="firstname_field" type="sql" default="" label="PLG_WICKEDTEAM_USERUPDATE_FIRSTNAME_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_FIRSTNAME_DESC" required="true" query="SELECT title, id FROM #__fields WHERE context='com_wickedteam.member'" key_field="id" value_field="title"/>
				<field type="spacer" name="spacer1" label="&lt;hr&gt;"/>
				<field name="update_joomla_user_email" type="radio" default="1" label="PLG_WICKEDTEAM_USERUPDATE_UPDATE_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_UPDATE_DESC">
					<option value="1">JYES</option>
					<option value="0">JNO</option>
				</field>
				<field name="email_field" type="sql" default="" label="PLG_WICKEDTEAM_USERUPDATE_EMAIL_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_EMAIL_DESC" required="true" query="SELECT title, id FROM #__fields WHERE context='com_wickedteam.member'" key_field="id" value_field="title"/>
				<field type="spacer" name="spacer2" label="&lt;hr&gt;"/>
				<field name="debug_output" type="checkbox" label="PLG_WICKEDTEAM_USERUPDATE_DEBUG_OUTPUT_LABEL" description="PLG_WICKEDTEAM_USERUPDATE_DEBUG_OUTPUT_DESC" value="1" default="0"/>
			</fieldset>
		</fields>
	</config>
	<changelogurl>https://raw.githubusercontent.com/heinchrs/plg_content_wickedteam_userupdate/master/.release/changelog.xml</changelogurl>
	<updateservers>
		<server name="Wickedteam Userupdate update server" type="extension" priority="1">
			https://raw.githubusercontent.com/heinchrs/plg_content_wickedteam_userupdate/master/.release/wickedteam_userupdate_update.xml
		</server>
	</updateservers>
</extension>
